{
  "name": "harvverse-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev:web": "turbo run dev --filter=web",
    "db:push": "turbo run db:push --filter=@harvverse-monorepo/db",
    "db:studio": "turbo run db:studio --filter=@harvverse-monorepo/db",
    "db:generate": "turbo run db:generate --filter=@harvverse-monorepo/db",
    "db:migrate": "turbo run db:migrate --filter=@harvverse-monorepo/db",
    "db:seed": "turbo run db:seed --filter=@harvverse-monorepo/db",
    "db:start": "turbo run db:start --filter=@harvverse-monorepo/db",
    "db:watch": "turbo run db:watch --filter=@harvverse-monorepo/db",
    "db:stop": "turbo run db:stop --filter=@harvverse-monorepo/db",
    "db:down": "turbo run db:down --filter=@harvverse-monorepo/db",
    "infra:build": "turbo run build --filter=@harvverse-monorepo/infra",
    "infra:synth": "turbo run cdk:synth --filter=@harvverse-monorepo/infra",
    "infra:diff": "turbo run cdk:diff --filter=@harvverse-monorepo/infra",
    "infra:deploy": "turbo run cdk:deploy --filter=@harvverse-monorepo/infra",
    "infra:deploy:all": "turbo run cdk:deploy:all --filter=@harvverse-monorepo/infra",
    "infra:bootstrap": "turbo run cdk:bootstrap --filter=@harvverse-monorepo/infra",
    "infra:destroy": "turbo run cdk:destroy --filter=@harvverse-monorepo/infra",
    "infra:test": "turbo run test --filter=@harvverse-monorepo/infra",
    "docker:build:web": "docker build --build-arg NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=${NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY} -t harvverse/web:local -f apps/web/Dockerfile .",
    "docker:build:migrate": "docker build -t harvverse/migrate:local -f packages/db/Dockerfile.migrate .",
    "ecs:run-migrate": "bash scripts/ecs/run-db-migrate.sh"
  },
  "dependencies": {
    "@harvverse-monorepo/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@harvverse-monorepo/config": "workspace:*",
    "@types/node": "^22.13.14",
    "turbo": "^2.8.12",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.17.1"
}
