# Server-side
CORS_ORIGIN=http://localhost:3001
DATABASE_URL=postgresql://postgres:password@localhost:5432/harvverse-monorepo

# Clerk authentication — get keys from https://clerk.com/dashboard
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Copernicus / satellite data (optional — risk scoring degrades gracefully without these)
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=
CDS_API_KEY=

# Private S3 image storage (optional locally; falls back to database storage when unset)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_FARM_IMAGES_BUCKET=
S3_FARM_IMAGES_PREFIX=farm-images
S3_SIGNED_URL_TTL_SECONDS=900

# Local Hardhat demo contracts — populated automatically by `pnpm setup:demo`
# Leave blank when deploying to Celo Sepolia; set them from your deployment output.
NEXT_PUBLIC_USE_LOCAL_CONTRACTS=true
NEXT_PUBLIC_HARDHAT_CHAIN_ID=31337
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_PARTNERSHIP_ADDRESS=
