# Required server env
# In production, use the deployed web origin. For local dev, use http://localhost:3001.
CORS_ORIGIN=https://your-domain.com
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE?sslmode=require

# Required Clerk auth env
# Redirects are configured in code:
# - sign in -> /dashboard
# - sign up -> /onboarding
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Copernicus / satellite scoring
# Recommended for beta. If unset, scoring degrades to fallback evidence where possible.
SENTINEL_HUB_CLIENT_ID=
SENTINEL_HUB_CLIENT_SECRET=

# Optional climate provider key. Current scoring can run without this.
CDS_API_KEY=

# Optional private S3 image storage
# If these are unset, farm image storage falls back to database-backed storage.
AWS_REGION=us-east-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
S3_FARM_IMAGES_BUCKET=
S3_FARM_IMAGES_PREFIX=farm-images
S3_SIGNED_URL_TTL_SECONDS=900

# Optional investment contract configuration
# For beta production, keep local contracts disabled and set deployed contract addresses
# only if the investment/reserve flow is enabled.
NEXT_PUBLIC_USE_LOCAL_CONTRACTS=false
NEXT_PUBLIC_HARDHAT_CHAIN_ID=
NEXT_PUBLIC_USDC_ADDRESS=
NEXT_PUBLIC_PARTNERSHIP_ADDRESS=

# Optional contract deployment env, not needed by the web app at runtime.
CELO_SEPOLIA_RPC_URL=
DEPLOYER_PRIVATE_KEY=
