{
  "name": "@harvverse-monorepo/infra",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "tsc",
    "watch": "tsc -w",
    "check-types": "tsc --noEmit",
    "test": "jest",
    "cdk": "cdk --profile Harvverse",
    "cdk:synth": "cdk --profile Harvverse synth",
    "cdk:diff": "cdk --profile Harvverse diff",
    "cdk:deploy": "cdk --profile Harvverse deploy --require-approval never",
    "cdk:deploy:all": "cdk --profile Harvverse deploy --all --require-approval never",
    "cdk:deploy:interactive": "cdk --profile Harvverse deploy",
    "cdk:deploy:network": "cdk --profile Harvverse deploy Harvversev2Network --require-approval never",
    "cdk:deploy:ecr": "cdk --profile Harvverse deploy Harvversev2Ecr --require-approval never",
    "cdk:deploy:data": "cdk --profile Harvverse deploy Harvversev2Data --require-approval never",
    "cdk:deploy:storage": "cdk --profile Harvverse deploy Harvversev2Storage --require-approval never",
    "cdk:deploy:platform": "cdk --profile Harvverse deploy Harvversev2Platform --require-approval never",
    "cdk:deploy:web": "cdk --profile Harvverse deploy Harvversev2Web --require-approval never",
    "cdk:deploy:migrate": "cdk --profile Harvverse deploy Harvversev2Migrate --require-approval never",
    "cdk:deploy:cicd": "cdk --profile Harvverse deploy Harvversev2Cicd --require-approval never",
    "cdk:bootstrap": "cdk --profile Harvverse bootstrap",
    "cdk:destroy": "cdk --profile Harvverse destroy"
  },
  "dependencies": {
    "aws-cdk-lib": "^2.255.0",
    "constructs": "^10.5.0"
  },
  "devDependencies": {
    "@harvverse-monorepo/config": "workspace:*",
    "@types/jest": "^30",
    "@types/node": "^22.13.14",
    "aws-cdk": "2.1124.1",
    "jest": "^30",
    "ts-jest": "^29",
    "typescript": "catalog:"
  }
}
